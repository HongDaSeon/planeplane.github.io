rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 자유게시판 - 누구나 읽기/쓰기 가능
    match /board/{postId} {
      allow read, write: if true;
      match /comments/{commentId} {
        allow read, write: if true;
      }
    }
    // 공지사항 - 누구나 읽기, 쓰기/삭제도 허용 (관리자 인증은 클라이언트에서 처리)
    match /notice/{postId} {
      allow read, write: if true;
    }
    // 항공기 콘텐츠 - 누구나 읽기, 쓰기도 허용 (관리자 인증은 클라이언트에서 처리)
    match /site_contents/{docId} {
      allow read, write: if true;
    }
  }
}
